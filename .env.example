# Telegram credentials (required for real sends; not needed for --dry-run)
# 1. Create a bot via @BotFather -> copy the token below.
# 2. Message your bot once, then read your numeric chat_id (see README).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Send the same digest to several chats/channels (comma or space separated).
# TELEGRAM_CHAT_ID above is still honored; ids from both are merged + de-duped.
# TELEGRAM_CHAT_IDS=

# Optional AI one-line summaries via Groq (https://console.groq.com/keys).
# Leave GROQ_API_KEY empty to keep the bot LLM-free (the default). Set
# AI_SUMMARIES=0 to disable even when a key is present.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# AI_SUMMARIES=1

# Optional tuning (defaults shown)
# WINDOW_HOURS=26
